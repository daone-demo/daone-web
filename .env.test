# 测试环境（本地 dev:test 使用）
NODE_ENV = 'production'

# 当前环境标识
VITE_APP_ENV = 'test'

# 走同源 /api，由 vite proxy 转发到测试后端
VITE_API_BASE_URL = '/api/v1'

VITE_API_BASE_HOST = 'https://api-test.daoneai.com'

# api-test 开启了 Vercel Deployment Protection，本地代理需带 bypass 头。
# 在 Vercel 项目 Settings → Deployment Protection → Protection Bypass for Automation 获取密钥，
# 写入 .env.test.local（已 gitignore）：VITE_VERCEL_PROTECTION_BYPASS=你的密钥